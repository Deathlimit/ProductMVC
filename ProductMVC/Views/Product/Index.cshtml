@model ProductMVC.ViewModels.ProductsPageViewModel

@{
    ViewData["Title"] = "Products";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>Products</h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="/products/create" class="btn btn-primary">Add New Product</a>
            <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#batchInsertModal">Batch Insert</button>
            <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#batchUpdateModal" id="batchUpdateBtn">Batch Update</button>
            <button type="button" class="btn btn-danger" id="batchDeleteBtn">Batch Delete Selected</button>
        </div>
    </div>


    <div class="row mb-3">
        <div class="col-md-12">
            <input type="checkbox" id="selectAllCheckbox" /> <strong>Select All</strong>
        </div>
    </div>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th><input type="checkbox" class="select-checkbox" /></th>
                <th>ID</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model.Products.Items)
            {
                <tr>
                    <td><input type="checkbox" class="select-checkbox" data-id="@product.Id" /></td>
                    <td>@product.Id</td>
                    <td>@product.Name</td>
                    <td>@(string.IsNullOrEmpty(product.Category) ? "-" : product.Category)</td>
                    <td>$@product.Price.ToString("F2")</td>
                    <td>@product.Quantity</td>
                    <td>
                        <a href="/products/edit/@product.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a href="/products/delete/@product.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>


    @if (Model.Products.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @if (Model.Products.HasPrevious)
                {
                    <li class="page-item">
                        <a class="page-link" href="/products?page=@(Model.Products.Page - 1)">Previous</a>
                    </li>
                }

                @for (int i = 1; i <= Model.Products.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Products.Page ? "active" : "")">
                        <a class="page-link" href="/products?page=@i">@i</a>
                    </li>
                }

                @if (Model.Products.HasNext)
                {
                    <li class="page-item">
                        <a class="page-link" href="/products?page=@(Model.Products.Page + 1)">Next</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <div class="text-muted">
        <p>Total: @Model.Products.TotalCount products | Page @Model.Products.Page of @Model.Products.TotalPages</p>
    </div>
</div>


<div class="modal fade" id="batchInsertModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Batch Insert Products</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="productsContainer">
                    <div class="product-row mb-3">
                        <div class="row">
                            <div class="col-md-4"><input type="text" class="form-control product-name" placeholder="Product Name"></div>
                            <div class="col-md-2"><input type="number" class="form-control product-price" placeholder="Price" step="0.01"></div>
                            <div class="col-md-2"><input type="number" class="form-control product-quantity" placeholder="Qty"></div>
                            <div class="col-md-4"><input type="text" class="form-control product-category" placeholder="Category"></div>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn btn-secondary" id="addProductRow">+ Add Row</button>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success" id="submitBatchInsert">Insert Products</button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="batchUpdateModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Batch Update Products</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="updateProductsContainer">

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-info" id="submitBatchUpdate">Update Products</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/batch-operations.js"></script>
}
