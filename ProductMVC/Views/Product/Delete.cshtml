@model ProductMVC.BLL.DTO.ProductDTO

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="alert alert-warning">
                <h3>Are you sure?</h3>
            </div>

            <div class="card">
                <div class="card-body">
                    <p><strong>Name:</strong> @Model.Name</p>
                    <p><strong>Category:</strong> @(string.IsNullOrEmpty(Model.Category) ? "-" : Model.Category)</p>
                    <p><strong>Price:</strong> $@Model.Price.ToString("F2")</p>
                    <p><strong>Quantity:</strong> @Model.Quantity</p>
                </div>
            </div>

            <form method="post" asp-action="DeleteConfirmed" asp-route-id="@Model.Id" class="mt-3">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a href="/products" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
